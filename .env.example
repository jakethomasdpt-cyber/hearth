# Neon Postgres connection string (Dashboard -> Connect -> copy "Connection string")
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Base URL of the app
AUTH_URL="http://localhost:3000"

# ----- Teller bank sync (https://teller.io, free up to 100 connections) -----
# Application ID from your Teller dashboard
TELLER_APPLICATION_ID=""
# sandbox | development | production
TELLER_ENVIRONMENT="sandbox"
# Client certificate + private key from the Teller dashboard, base64-encoded:
#   base64 -i certificate.pem | tr -d '\n'
# Required for development/production; leave empty for sandbox.
TELLER_CERTIFICATE=""
TELLER_PRIVATE_KEY=""

# Shared secret protecting the daily sync endpoint (/api/sync)
# Generate with: openssl rand -hex 32
CRON_SECRET=""
